# Copy this file to .env and fill in real values.
#
# The harness reads .env automatically from the project root.
# Real .env files are git-ignored.

MIMO_API_KEY=
MIMO_BASE_URL=https://api.mimo.chat/v1
MIMO_MODEL=mimo-v1
MIMO_TIMEOUT=60

# Markdown memory persistence. Workbench defaults to memories/workbench.
ASSIST_MEMORY_PERSIST=1
ASSIST_MEMORY_DIR=memories/default

# Optional long-term memory backend.
# local: Markdown/JSON memory store; mem0: mirror/search long-term memory through a Mem0-compatible service.
ASSIST_MEMORY_BACKEND=local
MEM0_PROJECT_NAME=
MEM0_BASE_URL=
MEM0_API_KEY=
MEM0_USER_ID=workbench-user
MEM0_APP_ID=assist-everything-betterandbetter-skill
MEM0_TIMEOUT=15
