# Copy this file to .env and fill in real values.
#
# The harness reads .env automatically from the project root.
# Real .env files are git-ignored.

MIMO_API_KEY=
MIMO_BASE_URL=https://api.mimo.chat/v1
MIMO_MODEL=mimo-v1
MIMO_TIMEOUT=60

# Markdown memory persistence. Workbench defaults to memories/workbench.
ASSIST_MEMORY_PERSIST=1
ASSIST_MEMORY_DIR=memories/default
